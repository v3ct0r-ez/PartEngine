{
  "name": "partengine",
  "version": "0.0.1",
  "private": true,
  "description": "PartEngine — Enterprise Warehouse Management System for electronic components",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @partengine/web test:e2e",
    "desktop:dev": "pnpm --filter @partengine/core build && pnpm --filter @partengine/api prisma:generate && pnpm --filter @partengine/api build && pnpm --filter @partengine/web build && node apps/desktop/scripts/dev-assets.mjs && pnpm --filter @partengine/desktop start",
    "db:generate": "pnpm --filter @partengine/api prisma:generate",
    "db:migrate": "pnpm --filter @partengine/api prisma:migrate",
    "db:seed": "pnpm --filter @partengine/api prisma:seed",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "argon2",
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "sharp",
      "@embedded-postgres/windows-x64",
      "@embedded-postgres/linux-x64",
      "@embedded-postgres/darwin-arm64",
      "@embedded-postgres/darwin-x64"
    ]
  }
}
